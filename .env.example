APP_ENV=local
HTTP_ADDR=:8080
LOG_LEVEL=info

POSTGRES_DSN=postgres://sentry:sentry@postgres:5432/sentry?sslmode=disable
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DATABASE=sentry
CLICKHOUSE_USERNAME=sentry
CLICKHOUSE_PASSWORD=sentry
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
NATS_URL=nats://nats:4222
RAW_EVENT_STREAM=EVENTS
RAW_EVENT_SUBJECT=events.raw
RAW_TRANSACTION_SUBJECT=transactions.raw
RAW_SESSION_SUBJECT=sessions.raw
RAW_ATTACHMENT_SUBJECT=attachments.raw
RAW_PROFILE_SUBJECT=profiles.raw
RAW_REPLAY_SUBJECT=replays.raw
RAW_OUTCOME_SUBJECT=outcomes.raw
UNSUPPORTED_ITEM_SUBJECT=envelopes.unsupported
NORMALIZED_EVENT_SUBJECT=events.normalized
GROUPED_EVENT_SUBJECT=events.grouped
ALERT_EVENT_SUBJECT=alerts.triggered
DEAD_LETTER_SUBJECT=events.dlq
NORMALIZE_CONSUMER=worker-normalize
GROUPING_CONSUMER=worker-grouping
EVENT_WRITER_CONSUMER=worker-event-writer
ALERT_CONSUMER=worker-alert
ALERT_SUPPRESS_SECONDS=300
MAX_ENVELOPE_BYTES=262144
MAX_RELEASE_FILE_BYTES=20971520
DEFAULT_RATE_LIMIT_PER_MINUTE=6000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sentry-artifacts

# Seeded by migrations for local sentry-cli/API compatibility.
SENTRY_AUTH_TOKEN=demo-api-token
